index 0c22f97..faf7654 100644
--- a/src/components/data-entry/DataEntryPage.tsx
+++ b/src/components/data-entry/DataEntryPage.tsx
@@ -1377,41 +1377,46 @@ export function DataEntryPage() {
                                         </div>
